# ============================================================
# WealthEngine – Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wealthengine
DB_USERNAME=postgres
DB_PASSWORD=changeme

# --- Dhan API (Primary Market Data) ---
# Get from: https://dhanhq.co/docs/v2/
DHAN_CLIENT_ID=your_dhan_client_id
DHAN_ACCESS_TOKEN=your_dhan_access_token
DHAN_BASE_URL=https://api.dhan.co

# --- AngelOne API (Alternative / Fallback) ---
# Get from: https://smartapi.angelbroking.com/
ANGELONE_API_KEY=your_angelone_api_key
ANGELONE_CLIENT_CODE=your_angelone_client_code
ANGELONE_MPIN=your_angelone_mpin
ANGELONE_TOTP_SECRET=your_angelone_totp_secret

# --- OpenAI (LLM + Embeddings) ---
OPENAI_API_KEY=your_openai_api_key
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- JWT Security ---
JWT_SECRET=your_very_long_base64_encoded_jwt_secret_256_bits_minimum
JWT_EXPIRY_MS=86400000

# --- Email (Daily 9AM Reports) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_REPORT_RECIPIENT=recipient@example.com
